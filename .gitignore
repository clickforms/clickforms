# Dependencies
node_modules/
SAFE_TO_DELETE_stale_node_modules/
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Next.js
.next/
out/

# Production build
build/
dist/

# Env files — never commit real secrets
.env
.env*.local

# Prisma
prisma/*.db

# Testing
coverage/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor / OS
.DS_Store
.vscode/*
!.vscode/extensions.json
*.pem

# AWS Client VPN: CA key, server/client certs, and .ovpn configs (embeds private keys) —
# generated locally by scripts/setup-client-vpn.sh, never commit
.vpn/

# Vercel (unused, but harmless to ignore if it ever appears)
.vercel

# TypeScript incremental build info
*.tsbuildinfo
AWSCLIV2.pkg
