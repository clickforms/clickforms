# Local development only — copy to .env.local, never commit real values.
# Production secrets live in AWS SSM Parameter Store, not here.

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/forms_dev"
SESSION_SECRET="dev-only-change-me"
NEXTAUTH_URL="http://localhost:3000"

# Root domain public form pages hang subdomains off of, e.g. an org with subdomain
# "carecircle" is served at carecircle.clickforms.com.au. No scheme, no port — just the
# bare host. src/middleware.ts strips this suffix off the request host to find the
# subdomain. For local dev, use a host that supports subdomains without /etc/hosts
# edits, e.g. "localtest.me" (wildcard-resolves *.localtest.me -> 127.0.0.1).
ROOT_DOMAIN="clickforms.com.au"

# Required for file_upload/signature fields (spec 04) — point at the real AWS S3 bucket
# (see scripts/setup-s3.sh). Credentials are picked up from the standard AWS provider
# chain — the EC2 instance role in production (ARCHITECTURE.md §3/§7), or your local
# `aws configure`/SSO profile for dev. AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY below are
# only needed for local dev if you don't have a shared AWS CLI profile active — leave
# them unset in production, where the instance role covers it.
S3_BUCKET=""
AWS_REGION="ap-southeast-2"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# Leave unset — this now points at real AWS S3. Only set this to point at an
# S3-compatible provider instead of AWS (e.g. for a throwaway local/test bucket).
# Formerly used to point at Supabase Storage as a stand-in while the AWS account was
# blocked on signup; that migration is done (see scripts/migrate-supabase-to-s3.sh),
# so this should stay empty now.
S3_ENDPOINT=""

# Outbound email (self-service signup's verification link — see src/lib/email.ts).
# Leave SMTP_HOST unset for local dev: the verify link is logged to the console and
# also returned as `devVerifyUrl` from POST /api/auth/signup instead of being emailed.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="Clickforms <no-reply@localhost>"
